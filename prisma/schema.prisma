generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Employee {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  role       String
  department String
  location   String
  salary     Float
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  activities Activity[]
}

model Activity {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  action     String
  status     String   // 'Done', 'Pending', 'Alert'
  createdAt  DateTime @default(now())
}
